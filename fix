%% Remove Mobilab / PropertyGrid path conflict

fprintf('\nBefore cleanup, MATLAB finds strsplit here:\n');
which strsplit -all

allPathFolders = regexp(path, regexptranslate('escape', pathsep), 'split');

badPathFolders = {};

for k = 1:numel(allPathFolders)
    thisFolder = allPathFolders{k};
    thisFolderLower = lower(thisFolder);

    if contains(thisFolderLower, 'mobilab') || contains(thisFolderLower, 'propertygrid')
        badPathFolders{end+1} = thisFolder;
    end
end

if isempty(badPathFolders)
    fprintf('\nNo Mobilab or PropertyGrid folders were found on the MATLAB path.\n');
    fprintf('Copy/paste the output from "which strsplit -all" so we can see the exact bad path.\n');
else
    fprintf('\nRemoving these folders from the MATLAB path:\n');
    disp(badPathFolders')

    for k = 1:numel(badPathFolders)
        rmpath(badPathFolders{k});
    end

    savepath
    clear functions
    rehash toolboxcache

    fprintf('\nAfter cleanup, MATLAB finds strsplit here:\n');
    which strsplit -all
end
